#!/usr/bin/env bash

set -euo pipefail

script_dir=$(cd "$(dirname "$0")" && pwd)
local_bin="$HOME/.local/bin"
dmenu=rofi-dmenu
[ -x "$script_dir/rofi-dmenu" ] && dmenu="$script_dir/rofi-dmenu"

choice=$(cat <<'EOF' | "$dmenu" --width 760 --placeholder "Select workflow"
Launcher
Clipboard history
Keybind overview
Focus or open PDF
Open PDF
Passwords
Add OTP from QR code
Bookmarks
Ask Codex
Pick color
Lofi stream
Monitor layout: home
Monitor layout: office
Monitor layout: mirror
Monitor layout: remote
Lock screen
EOF
)

case "$choice" in
    "Launcher") exec rofi -matching fuzzy -case-smart -show drun ;;
    "Clipboard history") exec "$local_bin/cliphist-rofi" ;;
    "Keybind overview") exec "$local_bin/keybinds-overview" ;;
    "Focus or open PDF") exec "$local_bin/fuzzy-focus-pdf.nu" ;;
    "Open PDF") exec "$local_bin/pdf-open" ;;
    "Passwords") exec "$local_bin/dmenu-pass" ;;
    "Add OTP from QR code") exec "$local_bin/otp-gen" ;;
    "Bookmarks") exec "$local_bin/bookmarks" ;;
    "Ask Codex") exec "$local_bin/codex-rofi" ;;
    "Pick color") exec "$local_bin/my-hyprpicker" ;;
    "Lofi stream") exec "$local_bin/wofi-beats" ;;
    "Monitor layout: home") exec "$local_bin/monitor_config_home" ;;
    "Monitor layout: office") exec "$local_bin/monitor_config_office" ;;
    "Monitor layout: mirror") exec "$local_bin/monitor_config_mirror" ;;
    "Monitor layout: remote") exec "$local_bin/monitor_config_remote" ;;
    "Lock screen") exec hyprlock ;;
esac
