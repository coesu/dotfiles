#!/usr/bin/env bash

set -euo pipefail

hypr_scripts="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/scripts"
local_bin="$HOME/.local/bin"

choice=$(cat <<'EOF' | walker --dmenu --width 760 --placeholder "Select workflow"
Launcher
Clipboard history
Keybind overview
Focus or open PDF
Open PDF
Passwords
Add OTP from QR code
Bookmarks
Pick color
Lofi stream
Monitor layout: home
Monitor layout: office
Monitor layout: mirror
Monitor layout: remote
Lock screen
EOF
)

case "$choice" in
    "Launcher") exec walker ;;
    "Clipboard history") exec "$local_bin/cliphist-walker" ;;
    "Keybind overview") exec "$hypr_scripts/keybinds-overview" ;;
    "Focus or open PDF") exec "$hypr_scripts/fuzzy-focus-pdf.nu" ;;
    "Open PDF") exec "$hypr_scripts/pdf-open" ;;
    "Passwords") exec "$local_bin/dmenu-pass" ;;
    "Add OTP from QR code") exec "$local_bin/otp-gen" ;;
    "Bookmarks") exec "$local_bin/bookmarks" ;;
    "Pick color") exec "$hypr_scripts/my-hyprpicker" ;;
    "Lofi stream") exec "$hypr_scripts/wofi-beats" ;;
    "Monitor layout: home") exec "$hypr_scripts/monitor_config_home" ;;
    "Monitor layout: office") exec "$hypr_scripts/monitor_config_office" ;;
    "Monitor layout: mirror") exec "$hypr_scripts/monitor_config_mirror" ;;
    "Monitor layout: remote") exec "$hypr_scripts/monitor_config_remote" ;;
    "Lock screen") exec hyprlock ;;
esac
