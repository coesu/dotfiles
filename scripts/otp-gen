#!/usr/bin/env sh
paths_file=${DOTFILES_PATHS:-$(dirname "$(readlink -f "$0")")/dotfiles-paths}
[ -r "$paths_file" ] && . "$paths_file"
: "${DOTFILES_OTP_LIST:=$HOME/otp-list}"

name=$(walker --dmenu --inputonly --placeholder "OTP entry name" < /dev/null)

grim -g "$(slurp)" /tmp/qr-screenshot.png

qr_data=$(zbarimg -q --raw /tmp/qr-screenshot.png)

echo "$qr_data" | pass otp add "$name" && echo "$name" >> "$DOTFILES_OTP_LIST"

rm /tmp/qr-screenshot.png
